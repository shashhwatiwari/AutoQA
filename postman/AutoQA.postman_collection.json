    {
      "name": "Users – GET",
      "item": [

        {
          "name": "List users – page 1 (schema + types)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
              "pm.test('Response time < 5000 ms', () => pm.expect(pm.response.responseTime).to.be.below(5000));",
              "pm.test('Top-level schema keys present', () => {",
              "  const b = pm.response.json();",
              "  ['page','per_page','total','total_pages','data'].forEach(k => pm.expect(b).to.have.property(k));",
              "});",
              "pm.test('page is integer 1', () => pm.expect(pm.response.json().page).to.eql(1));",
              "pm.test('per_page is a positive integer', () => {",
              "  pm.expect(pm.response.json().per_page).to.be.a('number').and.above(0);",
              "});",
              "pm.test('total is a positive integer', () => {",
              "  pm.expect(pm.response.json().total).to.be.a('number').and.above(0);",
              "});",
              "pm.test('total_pages is a positive integer', () => {",
              "  pm.expect(pm.response.json().total_pages).to.be.a('number').and.above(0);",
              "});",
              "pm.test('data is a non-empty array', () => {",
              "  pm.expect(pm.response.json().data).to.be.an('array').and.have.length.above(0);",
              "});",
              "pm.test('Each user has required fields', () => {",
              "  pm.response.json().data.forEach(u => {",
              "    ['id','email','first_name','last_name','avatar'].forEach(k => pm.expect(u).to.have.property(k));",
              "  });",
              "});",
              "pm.test('All user IDs are positive integers', () => {",
              "  pm.response.json().data.forEach(u => pm.expect(u.id).to.be.a('number').and.above(0));",
              "});",
              "pm.test('All emails contain @', () => {",
              "  pm.response.json().data.forEach(u => pm.expect(u.email).to.include('@'));",
              "});",
              "pm.test('All avatars start with http', () => {",
              "  pm.response.json().data.forEach(u => pm.expect(u.avatar).to.match(/^https?:\\/\\//));",
              "});",
              "pm.collectionVariables.set('page1_ids', JSON.stringify(pm.response.json().data.map(u => u.id)));"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users?page=1"
          }
        },

        {
          "name": "List users – page 2 (disjoint IDs)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('page metadata equals 2', () => pm.expect(pm.response.json().page).to.eql(2));",
              "pm.test('data is non-empty array', () => {",
              "  pm.expect(pm.response.json().data).to.be.an('array').and.have.length.above(0);",
              "});",
              "pm.test('Page 2 IDs do not overlap with page 1', () => {",
              "  const p1 = JSON.parse(pm.collectionVariables.get('page1_ids') || '[]');",
              "  const p2 = pm.response.json().data.map(u => u.id);",
              "  const overlap = p1.filter(id => p2.includes(id));",
              "  pm.expect(overlap).to.be.empty;",
              "});"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users?page=2"
          }
        },

