        {
          "name": "Authenticated GET with Bearer token",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "if (!pm.collectionVariables.get('auth_token')) {",
                "  pm.sendRequest({",
                "    url: pm.collectionVariables.get('base_url') + '/login',",
                "    method: 'POST',",
                "    header: { 'Content-Type': 'application/json' },",
                "    body: { mode: 'raw', raw: JSON.stringify({ email: 'eve.holt@reqres.in', password: 'cityslicka' }) }",
                "  }, (err, res) => {",
                "    pm.collectionVariables.set('auth_token', res.json().token);",
                "  });",
                "}"
              ]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('Status is 200 with Bearer token', () => pm.response.to.have.status(200));",
                "pm.test('Response contains user data', () => pm.expect(pm.response.json()).to.have.property('data'));"
              ]}
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/2",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }]
          }
        },

        {
          "name": "Public endpoint without token – still 200",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Public endpoint accessible without token', () => pm.response.to.have.status(200));"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/2"
          }
        }

      ]
    }

  ]
}
