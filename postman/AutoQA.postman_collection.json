              "pm.test('first_name and last_name are non-empty strings', () => {",
              "  const u = pm.response.json().data;",
              "  pm.expect(u.first_name).to.be.a('string').and.have.length.above(0);",
              "  pm.expect(u.last_name ).to.be.a('string').and.have.length.above(0);",
              "});",
              "pm.test('email matches fixture value for id=2', () => {",
