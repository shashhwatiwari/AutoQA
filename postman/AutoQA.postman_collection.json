        {
          "name": "Login – valid credentials",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
              "pm.test('Response time < 5000 ms', () => pm.expect(pm.response.responseTime).to.be.below(5000));",
              "pm.test('Body has token key', () => pm.expect(pm.response.json()).to.have.property('token'));",
              "pm.test('Token is a non-empty string', () => {",
              "  const t = pm.response.json().token;",
              "  pm.expect(t).to.be.a('string').and.to.have.lengthOf.at.least(8);",
              "});",
              "pm.test('Response has ONLY token key', () => {",
              "  pm.expect(Object.keys(pm.response.json())).to.deep.equal(['token']);",
              "});",
              "pm.collectionVariables.set('auth_token', pm.response.json().token);"
            ]}
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"eve.holt@reqres.in\",\"password\":\"cityslicka\"}" }
